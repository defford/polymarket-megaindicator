# --- SSH-only mode (no domain) ---
# No .env file needed. Deploy with:
#   docker compose -f docker-compose.yml -f docker-compose.ssh.yml up -d app --build
# Access via: ssh -L 8080:127.0.0.1:3001 root@<droplet-ip>
# Then open http://localhost:8080

# --- Domain + HTTPS mode (optional) ---
# Use: docker compose up -d --build
# DOMAIN=btc.example.com
# BASIC_AUTH_USER=admin
# BASIC_AUTH_HASH=
# Generate hash: docker run --rm caddy:2-alpine caddy hash-password --plaintext 'your-password'

# App port inside the container (optional, default 3001)
PORT=3001
